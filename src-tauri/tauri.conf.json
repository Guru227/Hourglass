{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hourglass",
  "version": "0.4.0",
  "identifier": "com.guru227.hourglass",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Hourglass",
        "url": "index.html",
        "fullscreen": true,
        "transparent": false,
        "decorations": false,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "skipTaskbar": true,
        "resizable": true,
        "focus": true,
        "shadow": false,
        "visible": false
      },
      {
        "label": "settings",
        "title": "Hourglass Settings",
        "url": "settings.html",
        "width": 480,
        "height": 660,
        "minWidth": 420,
        "minHeight": 560,
        "resizable": true,
        "decorations": true,
        "center": true,
        "skipTaskbar": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
